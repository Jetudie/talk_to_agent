# Configuration for the Voice Agent

# Select which LLM backend to use: 'ollama', 'openai', or 'opencode'
LLM_BACKEND=opencode

# === OLLAMA CONFIGURATION ===
# Model to use if using Ollama (e.g., llama3, phi3, mistral)
OLLAMA_MODEL=llama3

# === OPENAI / COMPATIBLE API CONFIGURATION ===
# Model to use for OpenAI backend (e.g., gpt-3.5-turbo, gpt-4o, or a custom one)
OPENAI_MODEL=gpt-3.5-turbo

# API Key for OpenAI compatible backend
OPENAI_API_KEY=your_api_key_here

# Base URL (leave as default for standard OpenAI, change for local servers like LM Studio or vLLM)
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_BASE_URL=http://localhost:1234/v1

# === OPENCODE CONFIGURATION ===
# URL of the running opencode server (default is http://127.0.0.1:4096)
OPENCODE_SERVER_URL=http://127.0.0.1:4096

# Model to use in opencode (e.g., openai/gpt-4o)
# OPENCODE_MODEL=openai/gpt-4o

# Agent to use in opencode (to use pre-configured system prompts/settings)
# OPENCODE_AGENT=my-custom-agent

# === MEMORY CONFIGURATION ===
# Directory for persistent memory files (relative to project root)
MEMORY_DIR=memory

# Maximum number of session archives to keep on disk (oldest are pruned)
MAX_SESSION_ARCHIVES=10

# Number of recent session archives to inject into the memory context
SESSION_CONTEXT_COUNT=3

# Maximum number of relevant snippets from semantic retrieval
MAX_RETRIEVAL_SNIPPETS=5

# === WHISPER STT CONFIGURATION ===
# Model size: tiny, base, small, medium, large-v2, large-v3 (larger = more accurate but slower)
WHISPER_MODEL_SIZE=base

# Device: "auto" (uses GPU if available), "cpu", or "cuda"
WHISPER_DEVICE=auto

# Language: set to a language code (e.g. "en", "zh") for faster/more accurate results, or leave blank for auto-detect
# WHISPER_LANGUAGE=en

# === AUDIO RECORDING SETTINGS ===
# RMS energy threshold to detect speech (lower = more sensitive, higher = less sensitive)
SILENCE_THRESHOLD=500

# Seconds of silence after speech to stop recording
SILENCE_DURATION=1.5

# Maximum recording length in seconds
MAX_RECORD_SECONDS=30

# Maximum number of user+assistant messages to keep in conversation history (older messages are trimmed)
MAX_HISTORY_MESSAGES=20

# === LOGGING ===
# Log level: DEBUG, INFO, WARNING, ERROR (default: INFO)
LOG_LEVEL=INFO
